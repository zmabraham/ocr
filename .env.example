# OCR Workflow Configuration
# Copy this file to .env and update with your settings

# Application
APP_NAME=Hebrew OCR Post-Processor
VERSION=1.0.0
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://ocr_user:ocr_password@localhost:5432/ocr_workflow

# Redis
REDIS_URL=redis://localhost:6379/0

# OCR
TESSERACT_CMD=/usr/bin/tesseract
TESSERACT_LANG=heb

# AI Models
DICTABERT_MODEL=dicta-il/dictabert
DICTABERT_MORPH_MODEL=dicta-il/dictabert-morph
HEBERT_MODEL=avichr/heBERT
MODEL_CACHE_DIR=/workspace/ocr-workflow/models

# File Storage
UPLOAD_DIR=/workspace/ocr-workflow/uploads
MAX_FILE_SIZE=52428800

# Confidence Thresholds
CONFIDENCE_LOW=0.70
CONFIDENCE_MEDIUM=0.85

# Queue
OCR_QUEUE_NAME=ocr-process
REVIEW_QUEUE_NAME=review-queue
